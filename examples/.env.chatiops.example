# Exemplo de variáveis para integração OpenClaw + Chatiops
# Gere o token em Chatiops > Conexões > sua conexão WhatsApp > API > Gerar Token
# Preencha com seus dados reais em um arquivo fora do Git, por exemplo .env.chatiops

CHATIOPS_BASE_URL=https://api.chatiops.com
CHATIOPS_API_TOKEN=cole-aqui-o-token-gerado-no-chatiops
CHATIOPS_DEFAULT_DESTINATION=
CHATIOPS_DEFAULT_CHANNEL=whatsapp
CHATIOPS_ENVIRONMENT=production
