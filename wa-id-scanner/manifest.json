{
  "manifest_version": 3,
  "name": "WhatsApp ID Scanner (OpenClaw helper)",
  "version": "0.1.0",
  "description": "Shows/copies the current WhatsApp Web chat id (JID-like) to help automation.",
  "action": {
    "default_title": "WhatsApp ID Scanner",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "128": "icons/128.png"
  }
}
